# Database connection (async)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/codevector

# PostgreSQL container variables (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=codevector

# App settings
APP_NAME=CodeVector Product API
DEBUG=false
LOG_LEVEL=INFO
MAX_PAGE_LIMIT=100
DEFAULT_PAGE_LIMIT=20

# Test database
TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/codevector_test
